# Normalisation automatique des fins de ligne
* text=auto

# Forcer LF pour les fichiers web (standard universel)
*.html text eol=lf
*.css  text eol=lf
*.js   text eol=lf
*.svg  text eol=lf
*.json text eol=lf
*.md   text eol=lf

# Fichiers binaires – ne pas toucher aux fins de ligne
*.ico  binary
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.woff binary
*.woff2 binary